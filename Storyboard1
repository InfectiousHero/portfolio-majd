<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Storyboard 1 — Karim</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <style>
    body {
      font-family: 'Poppins', sans-serif;
      background-color: #f0ece4;
      color: #1a1a1a;
    }

    .page-header {
      background-color: #1a1a1a;
      color: #f5f0e8;
      padding: 40px 0 30px;
      margin-bottom: 50px;
    }

    .page-header h1 {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      margin-bottom: 6px;
    }

    .page-header h1 span { color: #c9a84c; }

    .page-header p {
      color: rgba(245,240,232,0.5);
      font-size: 0.88rem;
      margin: 0;
    }

    .back-link {
      color: rgba(245,240,232,0.4);
      font-size: 0.8rem;
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      display: inline-block;
      margin-bottom: 20px;
    }
    .back-link:hover { color: #c9a84c; }

    /* Persona card */
    .persona-card {
      background-color: #1a1a1a;
      color: #f5f0e8;
      padding: 28px;
      margin-bottom: 50px;
    }

    .persona-card h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem;
      margin-bottom: 4px;
    }

    .persona-card h3 span { color: #c9a84c; }

    .persona-card .role {
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(245,240,232,0.4);
      margin-bottom: 20px;
    }

    .persona-tag {
      display: inline-block;
      border: 1px solid rgba(245,240,232,0.2);
      padding: 4px 12px;
      font-size: 0.75rem;
      color: rgba(245,240,232,0.6);
      margin: 3px;
    }

    .persona-goal {
      background-color: rgba(201,168,76,0.12);
      border-left: 3px solid #c9a84c;
      padding: 12px 16px;
      margin-top: 20px;
      font-size: 0.88rem;
      color: rgba(245,240,232,0.8);
    }

    /* Step label */
    .step-label {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #999;
      margin-bottom: 8px;
    }

    .step-num {
      font-family: 'Playfair Display', serif;
      font-size: 1.8rem;
      font-weight: 700;
      color: #ddd;
      line-height: 1;
      margin-bottom: 4px;
    }

    .step-title {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 6px;
    }

    .step-desc {
      font-size: 0.82rem;
      color: #666;
      margin-bottom: 16px;
    }

    /* Mockup frames — dark theme */
    .mockup-frame {
      border: 2px solid #1a1a1a;
      background-color: #1a1a1a;
      color: #f5f0e8;
      overflow: hidden;
      width: 100%;
    }

    .mockup-bar {
      background-color: #111;
      padding: 8px 14px;
      display: flex;
      align-items: center;
      gap: 6px;
      border-bottom: 1px solid #333;
    }

    .mockup-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
    }

    .mockup-url {
      font-size: 0.65rem;
      color: rgba(245,240,232,0.25);
      margin-left: 8px;
    }

    .mockup-body {
      padding: 0;
    }

    /* Mini navbar inside mockup */
    .m-nav {
      background-color: #111;
      padding: 8px 14px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid #222;
    }

    .m-nav-brand {
      font-family: 'Playfair Display', serif;
      font-size: 0.75rem;
      color: #f5f0e8;
    }

    .m-nav-brand span { color: #c9a84c; }

    .m-nav-links {
      display: flex;
      gap: 10px;
    }

    .m-nav-links a {
      font-size: 0.6rem;
      color: rgba(245,240,232,0.5);
      text-decoration: none;
      text-transform: uppercase;
    }

    /* Mini hero */
    .m-hero {
      background-color: #1a1a1a;
      padding: 20px 14px 18px;
    }

    .m-hero-label {
      font-size: 0.55rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #c9a84c;
      margin-bottom: 6px;
    }

    .m-hero h2 {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      margin-bottom: 6px;
      line-height: 1.2;
    }

    .m-hero h2 em { color: #c9a84c; font-style: italic; }

    .m-hero p {
      font-size: 0.6rem;
      color: rgba(245,240,232,0.5);
      margin-bottom: 12px;
    }

    .m-btn-gold {
      background-color: #c9a84c;
      color: #1a1a1a;
      font-size: 0.6rem;
      padding: 5px 14px;
      text-transform: uppercase;
      font-weight: 600;
      border: none;
      cursor: pointer;
    }

    /* Mini services */
    .m-services {
      background-color: #f5f0e8;
      padding: 14px;
    }

    .m-services-title {
      font-family: 'Playfair Display', serif;
      font-size: 0.85rem;
      color: #1a1a1a;
      margin-bottom: 10px;
    }

    .m-service-row {
      display: flex;
      gap: 6px;
      margin-bottom: 6px;
    }

    .m-service-item {
      flex: 1;
      background-color: #ede7d6;
      border-left: 2px solid #1a6b3a;
      padding: 6px 8px;
    }

    .m-service-item .name {
      font-size: 0.58rem;
      font-weight: 600;
      color: #1a1a1a;
    }

    .m-service-item .price {
      font-size: 0.6rem;
      color: #1a6b3a;
      font-weight: 600;
    }

    /* Mini booking form */
    .m-booking {
      background-color: #1a1a1a;
      padding: 14px;
    }

    .m-booking-title {
      font-family: 'Playfair Display', serif;
      font-size: 0.85rem;
      color: #f5f0e8;
      margin-bottom: 10px;
    }

    .m-form-row {
      display: flex;
      gap: 6px;
      margin-bottom: 6px;
    }

    .m-form-field {
      flex: 1;
    }

    .m-form-label {
      font-size: 0.52rem;
      text-transform: uppercase;
      color: rgba(245,240,232,0.4);
      margin-bottom: 3px;
    }

    .m-form-input {
      background-color: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      height: 16px;
      width: 100%;
    }

    .m-form-input.filled {
      border-color: #c9a84c;
      background-color: rgba(201,168,76,0.08);
    }

    .m-btn-submit {
      background-color: #c9a84c;
      color: #1a1a1a;
      font-size: 0.58rem;
      padding: 5px 0;
      width: 100%;
      text-align: center;
      font-weight: 600;
      text-transform: uppercase;
      margin-top: 8px;
    }

    /* Mini confirmation */
    .m-confirm {
      background-color: #1a1a1a;
      padding: 14px;
    }

    .m-confirm-box {
      background-color: rgba(26,107,58,0.2);
      border: 1px solid #1a6b3a;
      padding: 12px;
      text-align: center;
    }

    .m-confirm-icon {
      font-size: 1.2rem;
      color: #1a6b3a;
      display: block;
      margin-bottom: 6px;
    }

    .m-confirm-title {
      font-family: 'Playfair Display', serif;
      font-size: 0.8rem;
      color: #f5f0e8;
      margin-bottom: 4px;
    }

    .m-confirm-text {
      font-size: 0.6rem;
      color: rgba(245,240,232,0.5);
    }

    /* Arrow between steps */
    .step-arrow {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 10px 0;
      color: #ccc;
      font-size: 1.2rem;
    }

    /* Footer nav */
    .page-footer {
      background-color: #1a1a1a;
      color: rgba(245,240,232,0.3);
      text-align: center;
      padding: 20px;
      font-size: 0.75rem;
      margin-top: 60px;
    }

    .page-footer a {
      color: #c9a84c;
      text-decoration: none;
      margin: 0 10px;
    }
  </style>
</head>
<body>

  <div class="page-header">
    <div class="container">
      <a href="../index.html" class="back-link"><i class="bi bi-arrow-left me-1"></i> Back to Portfolio</a>
      <h1>Storyboard <span>1</span></h1>
      <p>PrestigeCuts Barbershop · Dark Theme · SEG3125 Assignment 2 · Majd Al Khori — 300240467</p>
    </div>
  </div>

  <div class="container">

    <!-- Persona -->
    <div class="persona-card">
      <div class="row align-items-start">
        <div class="col-lg-7">
          <h3>Persona: <span>Karim</span></h3>
          <div class="role">University Student, 21 — Ottawa</div>
          <div>
            <span class="persona-tag">Tech-savvy</span>
            <span class="persona-tag">Busy schedule</span>
            <span class="persona-tag">Books everything online</span>
            <span class="persona-tag">Regular barbershop visitor</span>
          </div>
          <div class="persona-goal">
            <strong style="color:#c9a84c;">Goal:</strong> Karim wants to book a fade with Darius on Saturday at 11am without having to call anyone. He's used to doing everything on his phone and just wants a quick, simple booking experience.
          </div>
        </div>
        <div class="col-lg-4 offset-lg-1 mt-4 mt-lg-0">
          <p style="font-size:0.82rem; color:rgba(245,240,232,0.5); margin-bottom:10px;">Relation to technology</p>
          <p style="font-size:0.85rem; color:rgba(245,240,232,0.7); margin-bottom:16px;">Uses his phone for everything — food delivery, class registration, payments. Comfortable navigating websites and expects them to be fast.</p>
          <p style="font-size:0.82rem; color:rgba(245,240,232,0.5); margin-bottom:10px;">Relation to barbershops</p>
          <p style="font-size:0.85rem; color:rgba(245,240,232,0.7); margin:0;">Goes every 3–4 weeks. Has a preferred barber (Darius) and always gets a fade. Doesn't like waiting around — prefers to book ahead.</p>
        </div>
      </div>
    </div>

    <!-- Steps -->
    <div class="row g-4 align-items-start">

      <!-- Step 1 -->
      <div class="col-lg-4">
        <div class="step-label">Step</div>
        <div class="step-num">01</div>
        <div class="step-title">Karim lands on the homepage</div>
        <div class="step-desc">He opens the site on his phone, sees the hero section right away, and clicks "Book a Cut" without scrolling further.</div>

        <div class="mockup-frame">
          <div class="mockup-bar">
            <div class="mockup-dot" style="background:#ff5f57;"></div>
            <div class="mockup-dot" style="background:#febc2e;"></div>
            <div class="mockup-dot" style="background:#28c840;"></div>
            <span class="mockup-url">prestigecuts.ca</span>
          </div>
          <div class="mockup-body">
            <div class="m-nav">
              <div class="m-nav-brand">Prestige<span>cuts</span></div>
              <div class="m-nav-links">
                <a href="#">Services</a>
                <a href="#">Book</a>
                <a href="#">About</a>
              </div>
            </div>
            <div class="m-hero">
              <div class="m-hero-label">Ottawa's Local Barbershop</div>
              <h2>Look Good,<br /><em>Feel Better.</em></h2>
              <p>We're a small barbershop on Sparks Street. Good cuts, fair prices.</p>
              <button class="m-btn-gold">Book a Cut</button>
            </div>
            <div class="m-services" style="padding:10px 14px;">
              <div class="m-services-title" style="font-size:0.7rem; color:#888;">↓ Scroll for services</div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="step-arrow d-none d-lg-flex" style="padding-top:120px;"><i class="bi bi-arrow-right fs-3" style="color:#c9a84c;"></i></div>
      </div>

      <!-- Step 2 -->
      <div class="col-lg-4">
        <div class="step-label">Step</div>
        <div class="step-num">02</div>
        <div class="step-title">He fills in the booking form</div>
        <div class="step-desc">He selects Fade & Taper, picks Darius, chooses Saturday and 11am. Fills in his name and email.</div>

        <div class="mockup-frame">
          <div class="mockup-bar">
            <div class="mockup-dot" style="background:#ff5f57;"></div>
            <div class="mockup-dot" style="background:#febc2e;"></div>
            <div class="mockup-dot" style="background:#28c840;"></div>
            <span class="mockup-url">prestigecuts.ca/#booking</span>
          </div>
          <div class="mockup-body">
            <div class="m-nav">
              <div class="m-nav-brand">Prestige<span>cuts</span></div>
            </div>
            <div class="m-booking">
              <div class="m-booking-title">Book an Appointment</div>
              <div class="m-form-row">
                <div class="m-form-field">
                  <div class="m-form-label">First Name</div>
                  <div class="m-form-input filled"></div>
                </div>
                <div class="m-form-field">
                  <div class="m-form-label">Last Name</div>
                  <div class="m-form-input filled"></div>
                </div>
              </div>
              <div class="m-form-row">
                <div class="m-form-field">
                  <div class="m-form-label">Service</div>
                  <div class="m-form-input filled"></div>
                </div>
                <div class="m-form-field">
                  <div class="m-form-label">Barber</div>
                  <div class="m-form-input filled"></div>
                </div>
              </div>
              <div class="m-form-row">
                <div class="m-form-field">
                  <div class="m-form-label">Date</div>
                  <div class="m-form-input filled"></div>
                </div>
                <div class="m-form-field">
                  <div class="m-form-label">Time</div>
                  <div class="m-form-input filled"></div>
                </div>
              </div>
              <div class="m-btn-submit">Confirm Booking</div>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- Step 3 full width -->
    <div class="row g-4 mt-2">
      <div class="col-12 text-center mb-2">
        <i class="bi bi-arrow-down fs-3" style="color:#c9a84c;"></i>
      </div>
      <div class="col-lg-4 offset-lg-4">
        <div class="step-label">Step</div>
        <div class="step-num">03</div>
        <div class="step-title">Booking confirmed</div>
        <div class="step-desc">He submits the form and sees a green confirmation message with his name, service, date and time. Done — no phone call needed.</div>

        <div class="mockup-frame">
          <div class="mockup-bar">
            <div class="mockup-dot" style="background:#ff5f57;"></div>
            <div class="mockup-dot" style="background:#febc2e;"></div>
            <div class="mockup-dot" style="background:#28c840;"></div>
            <span class="mockup-url">prestigecuts.ca/#booking</span>
          </div>
          <div class="mockup-body">
            <div class="m-nav">
              <div class="m-nav-brand">Prestige<span>cuts</span></div>
            </div>
            <div class="m-confirm">
              <div class="m-booking-title" style="margin-bottom:12px;">Book an Appointment</div>
              <div class="m-confirm-box">
                <i class="bi bi-check-circle m-confirm-icon"></i>
                <div class="m-confirm-title">Booking Confirmed!</div>
                <div class="m-confirm-text">Karim — Fade &amp; Taper with Darius<br />Saturday, June 7 at 11:00 AM</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Link to storyboard 2 -->
    <div class="mt-5 pt-3" style="border-top: 1px solid #ddd;">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
          <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.1em; color:#999; margin-bottom:4px;">Also see</p>
          <a href="storyboard2.html" style="color:#1a6b3a; font-weight:600; font-size:0.95rem;">Storyboard 2 — Robert (Light Theme) <i class="bi bi-arrow-right ms-1"></i></a>
        </div>
        <a href="https://prestigecuts-barbershop.netlify.app" target="_blank" style="color:#c9a84c; font-size:0.88rem;">View Live Site <i class="bi bi-box-arrow-up-right ms-1"></i></a>
      </div>
    </div>

  </div>

  <div class="page-footer">
    <span>SEG3125 Assignment 2 · Majd Al Khori · 300240467 · University of Ottawa</span><br />
    <a href="../index.html">Portfolio</a>
    <a href="storyboard2.html">Storyboard 2</a>
    <a href="https://prestigecuts-barbershop.netlify.app" target="_blank">Live Site</a>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
