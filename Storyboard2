      font-size: 0.65rem;
      color: #1a6b3a;
      margin-top: 1px;
    }

    .m-contact-item .info {
      font-size: 0.58rem;
      color: #555;
      line-height: 1.4;
    }

    .m-contact-item .lbl {
      font-size: 0.52rem;
      text-transform: uppercase;
      color: #aaa;
      margin-bottom: 1px;
    }

    /* Hours table mini */
    .m-hours {
      background-color: #f5f0e8;
      padding: 10px 14px;
    }

    .m-hours table {
      width: 100%;
      font-size: 0.58rem;
      color: #555;
    }

    .m-hours table td {
      padding: 3px 0;
      border-bottom: 1px solid #e0dbd0;
    }

    .m-hours table td:last-child {
      text-align: right;
      color: #1a6b3a;
