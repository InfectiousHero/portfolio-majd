      margin-bottom: 4px;
    }

    .step-title {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 6px;
      color: #1a1a1a;
    }

    .step-desc {
      font-size: 0.82rem;
      color: #777;
      margin-bottom: 16px;
    }

    /* Mockup frames — light theme */
    .mockup-frame {
      border: 2px solid #ddd;
      background-color: #fff;
      overflow: hidden;
      width: 100%;
    }

    .mockup-bar {
      background-color: #f0f0f0;
      padding: 7px 12px;
      display: flex;
      align-items: center;
      gap: 5px;
      border-bottom: 1px solid #ddd;
    }

    .mockup-dot {
      width: 8px; height: 8px;
