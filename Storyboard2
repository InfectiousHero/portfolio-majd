      color: #1a1a1a;
    }

    .m-nav-brand span { color: #1a6b3a; }

    .m-nav-links {
      display: flex;
      gap: 10px;
    }

    .m-nav-links a {
      font-size: 0.6rem;
      color: #888;
      text-decoration: none;
      text-transform: uppercase;
    }

    /* Mini hero — light */
    .m-hero {
      background-color: #f5f0e8;
      padding: 18px 14px;
    }

    .m-hero-label {
      font-size: 0.55rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #999;
      margin-bottom: 5px;
    }

    .m-hero h2 {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      color: #1a1a1a;
      margin-bottom: 5px;
      line-height: 1.2;
    }

