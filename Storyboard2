      color: #fff;
      font-size: 0.58rem;
      padding: 5px 12px;
      text-transform: uppercase;
      font-weight: 600;
      border: none;
      display: inline-block;
    }

    /* Mini services — light */
    .m-services {
      background-color: #fff;
      padding: 12px 14px;
    }

    .m-services-title {
      font-family: 'Playfair Display', serif;
      font-size: 0.8rem;
      color: #1a1a1a;
      margin-bottom: 8px;
    }

    .m-service-row {
      display: flex;
      gap: 5px;
      margin-bottom: 5px;
    }

    .m-service-item {
      flex: 1;
      background-color: #f5f0e8;
      border-left: 2px solid #1a6b3a;
      padding: 5px 7px;
    }

    .m-service-item .name {
      font-size: 0.56rem;
      font-weight: 600;
      color: #1a1a1a;
    }

    .m-service-item .price {
      font-size: 0.58rem;
      color: #1a6b3a;
      font-weight: 600;
    }

    /* Mini contact — light */
    .m-contact {
      background-color: #fff;
      padding: 12px 14px;
    }

    .m-contact-title {
      font-family: 'Playfair Display', serif;
      font-size: 0.8rem;
      color: #1a1a1a;
      margin-bottom: 10px;
    }

    .m-contact-item {
      display: flex;
      align-items: flex-start;
      gap: 6px;
      margin-bottom: 7px;
    }

